# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ENCRYPTION_KEY=your-encryption-key-here-separate-from-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite for development, PostgreSQL for production)
DATABASE_URL=sqlite:///db.sqlite3
# For PostgreSQL: postgresql://user:password@localhost:5432/lora_db

# Email Configuration (for communications app)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# IMAP Settings (for fetching emails)
IMAP_HOST=imap.gmail.com
IMAP_USER=your-email@gmail.com
IMAP_PASS=your-app-password

# Zendesk Settings
ZENDESK_SUBDOMAIN=your-subdomain
ZENDESK_TOKEN=your-zendesk-api-token
ZENDESK_EMAIL=your-email@company.com

# PayPal Settings
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_SECRET=your-paypal-secret
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id
PAYPAL_MODE=sandbox  # or 'live'

# Zendesk Sidebar Authentication
SIDEBAR_SECRET_TOKEN=your-sidebar-secret-token

# AI API Settings (DeepSeek, Qwen, or other OpenAI-compatible providers)
# Note: For production, configure these in SystemSettings (/manager/settings/)
AI_PROVIDER=DeepSeek  # or 'Qwen', 'OpenAI'
AI_API_BASE=https://api.deepseek.com/v1  # DeepSeek: https://api.deepseek.com/v1, Qwen: https://dashscope.aliyuncs.com/compatible-mode/v1
AI_API_KEY=your-ai-api-key
AI_API_MODEL=deepseek-chat  # DeepSeek: deepseek-chat, Qwen: qwen-plus

# PII tokenization secret (32+ bytes hex). Generate with: python -c "import secrets; print(secrets.token_hex(32))"
PII_TOKENIZATION_SALT=

# AI client behavior
AI_VALIDATION_STRICT=True
AI_TOKENIZER_BACKEND=regex
AI_PHONE_DEFAULT_REGION=US
AI_PHONE_FALLBACK_REGIONS=GB,FR,DE,IT,ES,JP

# API Timeout Settings (seconds, optional)
# API_TIMEOUT=30
# IMAP_TIMEOUT=30
# ZENDESK_TIMEOUT=30
# PAYPAL_TIMEOUT=30

# APScheduler Settings (optional)
# APSCHEDULER_DATETIME_FORMAT=N j, Y, f:s a
# APSCHEDULER_RUN_NOW_TIMEOUT=25
